#!/bin/bash
# =============================================================================
# jdoo - Docker Compose wrapper with smart defaults
# =============================================================================
# Usage:
#   ./jdoo up -d --build     # start
#   ./jdoo down               # stop
#   ./jdoo logs -f             # view logs
#   ./jdoo build --no-cache    # rebuild image
#
# Auto-computed from ODOO_VERSION (override any in .env):
#   PYTHON_VERSION       15-16 -> 3.10, 17+ -> 3.12
#   PG_VERSION           15->14, 16->15, 17-18->16, 19+->17
#   COMPOSE_PROJECT_NAME jdoo + major (15.0 -> jdoo15)
#
# PG tuning is handled inside the container by pg-auto-tune.sh
# (auto-computes from container RAM, respects Docker --memory limits).
# Override via .env: PG_SHARED_BUFFERS, PG_EFFECTIVE_CACHE_SIZE, etc.
# =============================================================================

set -euo pipefail

cd "$(dirname "$0")"

# Load .env if exists
if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

MAJOR="${ODOO_VERSION%%.*}"

# --- Auto-compute PYTHON_VERSION ---
if [ -z "${PYTHON_VERSION:-}" ]; then
    if [ "$MAJOR" -le 16 ]; then
        export PYTHON_VERSION="3.10"
    else
        export PYTHON_VERSION="3.12"
    fi
fi

# --- Auto-compute PG_VERSION ---
if [ -z "${PG_VERSION:-}" ]; then
    case "$MAJOR" in
        15) export PG_VERSION="14" ;;
        16) export PG_VERSION="15" ;;
        17|18) export PG_VERSION="16" ;;
        *) export PG_VERSION="17" ;;  # 19+
    esac
fi

# --- Auto-compute COMPOSE_PROJECT_NAME ---
if [ -z "${COMPOSE_PROJECT_NAME:-}" ]; then
    export COMPOSE_PROJECT_NAME="jdoo${MAJOR}"
fi

# PG tuning is handled automatically inside the container by pg-auto-tune.sh
# which reads cgroup-aware RAM (respects Docker --memory limits).
# Override via .env: PG_SHARED_BUFFERS, PG_EFFECTIVE_CACHE_SIZE, etc.

echo "[jdoo] Odoo ${ODOO_VERSION} | Python ${PYTHON_VERSION} | PG ${PG_VERSION} | Port ${ODOO_PORT:-8069} | Project ${COMPOSE_PROJECT_NAME}"

# --- Build compose file list ---
COMPOSE_FILES="-f docker-compose.yml"

exec docker compose ${COMPOSE_FILES} "$@"
